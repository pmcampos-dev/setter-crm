# Twilio Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número mexicano comprado en Twilio
TWILIO_PHONE_NUMBER=+521234567890

# TwiML App SID - se crea en Twilio Console > Voice > TwiML Apps
# El Request URL de la TwiML App debe apuntar a: https://tu-dominio.com/api/voice
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Key - se crea en Twilio Console > Account > API Keys
# Necesario para generar Access Tokens (no se puede usar Auth Token directamente)
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Calendly (opcional - para verificar webhooks)
CALENDLY_WEBHOOK_SECRET=

# Puerto del servidor
PORT=5000
